BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=iz_clinical_notes_analyzer_pgdata_app
USE_INTERNAL_POSTGRES=1
# internal | host | external
DATABASE_HOST_MODE=internal
POSTGRES_DB=iz_clinical_notes_analyzer
POSTGRES_USER=iz_clinical_notes
POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me
# Default DATABASE_URL is host-local for non-Docker backend runs.
DATABASE_URL=postgresql+psycopg2://iz_clinical_notes:change-me@127.0.0.1:5432/iz_clinical_notes_analyzer
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173
